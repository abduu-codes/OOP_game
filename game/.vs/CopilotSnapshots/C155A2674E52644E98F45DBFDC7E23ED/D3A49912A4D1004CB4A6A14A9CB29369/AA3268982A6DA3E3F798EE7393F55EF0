using MySql.Data.MySqlClient;
using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.Threading;

class GameEngine
{
    string connString = "Server=localhost; Database=CarGameDB; Uid=root; Pwd=minerooh.1;";

    public int width = 80; 
    public int height = 30; 
    public int score = 0;
    public bool isRunning = true;

    Car player;
    List<Obstacle> bodies = new List<Obstacle>();
    Random rnd = new Random();
    Stopwatch timer = new Stopwatch();
    char[] bodyShapes = { '#', '*', 'O', '@', 'X', '%' };
    ConsoleColor[] bodyColors = { ConsoleColor.Red, ConsoleColor.Yellow, ConsoleColor.Magenta, ConsoleColor.Green, ConsoleColor.White };

    public void StartGame()
    {
        Console.CursorVisible = false;
        Console.SetWindowSize(width + 5, height + 5);
        Console.Clear();

        DrawGameTitle();
        DrawBoundary();
        player = new Car(width / 2, height - 5);
        timer.Start();

        while (isRunning)
        {
            Update();
            Draw();
            Thread.Sleep(35);
        }

        EndGame();
    }

    void DrawGameTitle()
    {
        Console.ForegroundColor = ConsoleColor.Cyan;
        Console.SetCursorPosition(width / 2 - 15, 0);
        Console.Write("╔═══════════════════════════════╗");
        Console.SetCursorPosition(width / 2 - 15, 1);
        Console.Write("║     🚗 CAR DODGING 🚗        ║");
        Console.SetCursorPosition(width / 2 - 15, 2);
        Console.Write("╚═══════════════════════════════╝");
        Console.ResetColor();
    }

    void DrawBoundary()
    {
        Console.ForegroundColor = ConsoleColor.Gray;
        for (int i = 1; i < width; i++)
        {
            Console.SetCursorPosition(i, 1); 
            Console.Write("═");
            Console.SetCursorPosition(i, height); 
            Console.Write("═");
        }
        for (int i = 1; i <= height; i++)
        {
            Console.SetCursorPosition(1, i); Console.Write("║");
            Console.SetCursorPosition(width, i); Console.Write("║");
        }
    }

    void Update()
    {
        if (Console.KeyAvailable)
        {
            ConsoleKeyInfo key = Console.ReadKey(true);
            player.Clear();
            player.Move(key.Key, width, height);
        }
        if (rnd.Next(0, 100) < 15)
        {
            int rx = rnd.Next(2, width - 2);
            char rs = bodyShapes[rnd.Next(bodyShapes.Length)];
            ConsoleColor rc = bodyColors[rnd.Next(bodyColors.Length)];
            bodies.Add(new Obstacle(rx, 2, rs, rc));
        }

        for (int i = 0; i < bodies.Count; i++)
        {
            bodies[i].Clear();
            bodies[i].UpdatePosition();
            if (bodies[i].y == player.y && bodies[i].x >= player.x && bodies[i].x <= player.x + 6)
            {
                isRunning = false;
            }

            if (bodies[i].y >= height - 1)
            {
                bodies.RemoveAt(i);
                score++;
            }
        }
    }

    void Draw()
    {
        string timeStr = string.Format("{0:00}:{1:00}", (int)timer.Elapsed.TotalMinutes, timer.Elapsed.Seconds);

        Console.ForegroundColor = ConsoleColor.White;
        Console.SetCursorPosition(width / 2 - 10, 0);
        Console.Write($" SCORE: {score} | TIME: {timeStr} ");

        player.Draw();
        foreach (var b in bodies) b.Draw();
    }

    void EndGame()
    {
        timer.Stop();
        string finalTime = string.Format("{0:00}:{1:00}", (int)timer.Elapsed.TotalMinutes, timer.Elapsed.Seconds);

        Console.Beep(400, 500);
        SaveToMySQL(score, finalTime);
        Thread.Sleep(1000);
    }

    void SaveToMySQL(int finalScore, string finalTime)
    {
        try
        {
            using (MySqlConnection conn = new MySqlConnection(connString))
            {
                conn.Open();
                string query = "INSERT INTO HighScores (Score, TimeSurvived) VALUES (@s, @t)";
                using (MySqlCommand cmd = new MySqlCommand(query, conn))
                {
                    cmd.Parameters.AddWithValue("@s", finalScore);
                    cmd.Parameters.AddWithValue("@t", finalTime);
                    int rowsAffected = cmd.ExecuteNonQuery();
                    if (rowsAffected > 0)
                    {
                        Debug.WriteLine($"Score saved successfully: {finalScore} | Time: {finalTime}");
                    }
                }
            }
        }
        catch (MySqlException ex)
        {
            Debug.WriteLine("MySQL Error: " + ex.Message);
            Console.ForegroundColor = ConsoleColor.Red;
            Console.SetCursorPosition(2, height + 2);
            Console.Write($"Database Error: {ex.Message}");
            Console.ResetColor();
        }
        catch (Exception ex)
        {
            Debug.WriteLine("Error: " + ex.Message);
            Console.ForegroundColor = ConsoleColor.Red;
            Console.SetCursorPosition(2, height + 2);
            Console.Write($"Error: {ex.Message}");
            Console.ResetColor();
        }
    }
}